'use client';

import { useState } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import { 
  FolderKanban, Plus, Search, Filter, 
  ChevronRight, Calendar, Users, Target, 
  AlertCircle, CheckCircle, Clock, X, LayoutGrid, CalendarDays
} from 'lucide-react';

const PROJECTS = [
  { 
    id: 'a0eebc99-9c0b-4ef8-bb6d-6bb9bd380a11', 
    name: 'Project Phoenix', 
    status: 'active', 
    budget: '₹50L', 
    spent: '₹34L', 
    timeline: 'Apr 2025 - Mar 2026',
    vendors: 12,
    completion: 68
  },
  { 
    id: 'b0eebc99-9c0b-4ef8-bb6d-6bb9bd380a12', 
    name: 'Enterprise Suite', 
    status: 'active', 
    budget: '₹80L', 
    spent: '₹72L', 
    timeline: 'Jun 2025 - May 2026',
    vendors: 8,
    completion: 90
  },
  { 
    id: 'c0eebc99-9c0b-4ef8-bb6d-6bb9bd380a13', 
    name: 'Supply Chain AI', 
    status: 'planning', 
    budget: '₹35L', 
    spent: '₹1.2L', 
    timeline: 'Nov 2025 - Oct 2026',
    vendors: 0,
    completion: 5
  },
];

const CALENDAR_MONTHS = ['Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec', 'Jan', 'Feb', 'Mar'];

export default function ProjectsPage() {
  const [view, setView] = useState('grid');
  const [isModalOpen, setIsModalOpen] = useState(false);
  const [selectedProject, setSelectedProject] = useState(null);

  return (
    <main className="space-y-10 animate-slide-in pb-20">
      
      {/* Header */}
      <div className="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <h1 className="text-4xl font-black text-brand-black tracking-tighter mb-2">Project Governance</h1>
          <p className="text-gray-400 font-bold uppercase tracking-[0.2em] text-[10px]">Managing {PROJECTS.length} active audit nodes across sectors</p>
        </div>
        <div className="flex items-center gap-3">
          <div className="flex p-1 bg-surface-soft border border-black/[0.03] rounded-2xl mr-4 shadow-sm">
             <button onClick={() => setView('grid')} className={`p-2 rounded-xl transition-all ${view === 'grid' ? 'bg-white text-brand-black shadow-premium-sm' : 'text-gray-400'}`}>
                <LayoutGrid size={18} />
             </button>
             <button onClick={() => setView('calendar')} className={`p-2 rounded-xl transition-all ${view === 'calendar' ? 'bg-white text-brand-black shadow-premium-sm' : 'text-gray-400'}`}>
                <CalendarDays size={18} />
