                      animate={{ width: `${project.completion}%` }}
                      transition={{ duration: 1 }}
                      className="h-full bg-gradient-to-r from-brand-blue via-brand-pink to-brand-yellow" 
                    />
                  </div>
                  <div className="grid grid-cols-2 gap-4 mt-6">
                    <div className="p-3 bg-surface-soft rounded-2xl">
                      <p className="text-[8px] font-black text-gray-400 uppercase tracking-widest mb-1">Budget</p>
                      <p className="text-sm font-black text-brand-black">{project.budget}</p>
                    </div>
                    <div className="p-3 bg-surface-soft rounded-2xl">
                      <p className="text-[8px] font-black text-gray-400 uppercase tracking-widest mb-1">Vendors</p>
                      <p className="text-sm font-black text-brand-black">{project.vendors}</p>
                    </div>
                  </div>
                </div>
              </motion.div>
            ))}
          </motion.div>
